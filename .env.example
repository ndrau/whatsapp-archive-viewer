# Shared archive password (required unless ARCHIVE_AUTH_DISABLED=1)
ARCHIVE_PASSWORD=change-me

# HMAC secret for session cookies (min. 32 characters)
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Set to 1 to skip login (local development only)
# ARCHIVE_AUTH_DISABLED=1

# Max WhatsApp ZIP upload size in bytes (default 8GB)
# MAX_UPLOAD_BYTES=8589934592

# Allow uploading new chats via UI (default true). Set false to hide/disable.
ALLOW_CHAT_UPLOAD=true

# Allow deleting chats via UI (default false). Set true to enable.
ALLOW_CHAT_DELETE=true
