{
  "name": "whatsapp-archive-viewer",
  "description": "WhatsApp chat export viewer and HTML archiver",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "node scripts/next-dev-safe.mjs",
    "dev:webpack": "node scripts/next-dev-safe.mjs --webpack",
    "dev:full": "pnpm run build:chats && node scripts/next-dev-safe.mjs",
    "build:chats": "tsx scripts/build-chats.ts",
    "build:app": "node scripts/next-build-safe.mjs",
    "build": "pnpm run build:chats && pnpm run build:app",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && pnpm run lint",
    "start": "next start",
    "start:docker": "node scripts/docker-entrypoint.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/busboy": "^1.5.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
